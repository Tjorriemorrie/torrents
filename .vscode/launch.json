{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Django",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "runserver"
            ],
            "django": true,
            "autoStartBrowser": true,
            "program": "${workspaceFolder}\\manage.py"
        },
        {
            "name": "cmd scrape sites",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\manage.py",
            "args": ["scrape_sites"],
            "django": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "db make migrations",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\manage.py",
            "args": ["makemigrations"],
            "django": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "db migrate",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\manage.py",
            "args": ["migrate"],
            "django": true,
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
